{
  "name": "localcode-agent",
  "version": "0.1.1",
  "description": "Futuristic AI Developer Terminal & Autonomous Coding Agent",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/"
  ],
  "bin": {
    "localcode": "dist/localcode.js",
    "local": "dist/localcode.js"
  },
  "scripts": {
