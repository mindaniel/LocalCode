{
  "name": "localcode-terminal",
  "displayName": "LocalCode Terminal",
  "description": "Open a terminal and run localcode in the current workspace.",
  "version": "0.0.1",
  "publisher": "localcode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:localcode.openTerminal",
    "onView:localcode.view"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localcode.openTerminal",
        "title": "LocalCode: Terminal oeffnen"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localcode",
          "title": "LocalCode",
          "icon": "resources/localcode-icon.svg"
        }
      ]
    },
    "views": {
      "localcode": [
        {
          "id": "localcode.view",
          "name": "Chat",
          "type": "webview"
        }
      ]
    }
  }
}
